# =====================================================
# 外汇智能体环境变量配置模板
# 复制此文件为 .env 并填写你的配置
# =====================================================

# 默认 LLM 提供商 (gemini 或 chatglm)
LLM_PROVIDER=chatglm

# OpenAI API 密钥 (可选)
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI 模型选择 (可选, 默认 gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# OpenAI Base URL (可选, 用于代理或兼容API)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini API Key（可选，使用 gemini 时必填）
GEMINI_API_KEY=AIzaSyB-Ep0eE9kVI
GEMINI_MODEL=gemini-3-flash-preview

# ChatGLM / 智谱 API Key（可选，使用 chatglm 时必填）
CHATGLM_API_KEY=d0da122c43594d87a036fcf22c7d96a3.ONsw6cBnzhLqOqT3.ex123
CHATGLM_MODEL=glm-5

# 图表输出目录 (可选, 默认 ./charts)
CHARTS_DIR=./charts

# 日志级别 (可选: DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
